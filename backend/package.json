{
  "name": "functions",
  "scripts": {
    "lint": "eslint --ext .js,.ts .",
    "build": "tsc",
    "build:watch": "tsc --watch",
    "emulate": "nodemon --watch lib --ext js --delay 1 --exec \"firebase emulators:start --only functions\"",
    "serve": "npm run build && concurrently \"npm run build:watch\" \"npm run emulate\"",
    "shell": "npm run build && firebase functions:shell",
    "start": "npm run shell",
    "deploy": "firebase deploy --only functions",
    "logs": "firebase functions:log"
  },
  "engines": {
    "node": "24"
  },
  "main": "lib/backend/src/index.js",
  "dependencies": {
    "@google-cloud/datastore": "^10.1.0",
    "@types/express": "^5.0.6",
    "express": "^5.2.1",
    "firebase-admin": "^13.6.0",
    "firebase-functions": "^7.0.0"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^5.12.0",
    "@typescript-eslint/parser": "^5.12.0",
    "eslint": "^8.9.0",
    "eslint-config-google": "^0.14.0",
    "eslint-plugin-import": "^2.25.4",
    "firebase-functions-test": "^3.4.1",
    "concurrently": "^9.0.0",
    "nodemon": "^3.0.0",
    "typescript": "^5.7.3"
  },
  "private": true
}
