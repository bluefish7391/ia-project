# Normalize all text files to LF on checkout
* text=auto eol=lf

# Explicitly declare common text files
*.ts    text eol=lf
*.html  text eol=lf
*.scss  text eol=lf
*.json  text eol=lf
*.md    text eol=lf
*.js    text eol=lf
*.sh    text eol=lf

# Declare binary files (no conversion)
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.woff  binary
*.woff2 binary